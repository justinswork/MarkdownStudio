<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brushes -->
    <SolidColorBrush x:Key="MdsWindowBrush"         Color="#FCFCFC" />
    <SolidColorBrush x:Key="MdsRailBrush"           Color="#EEEEEF" />
    <SolidColorBrush x:Key="MdsSidebarBrush"        Color="#F7F7F8" />
    <SolidColorBrush x:Key="MdsSurfaceBrush"        Color="#FFFFFF" />
    <SolidColorBrush x:Key="MdsBorderBrush"         Color="#E4E4E8" />
    <SolidColorBrush x:Key="MdsTextPrimaryBrush"    Color="#14161C" />
    <SolidColorBrush x:Key="MdsTextSecondaryBrush"  Color="#6E727C" />
    <SolidColorBrush x:Key="MdsAccentBrush"         Color="#007ACC" />
    <SolidColorBrush x:Key="MdsAccentSoftBrush"     Color="#1F007ACC" />
    <SolidColorBrush x:Key="MdsAccentHoverBrush"    Color="#330078D4" />

    <!-- Typography -->
    <FontFamily x:Key="MdsUiFontFamily">Segoe UI Variable Display, Segoe UI Variable, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="MdsUiFontFamilyText">Segoe UI Variable Text, Segoe UI Variable, Segoe UI, sans-serif</FontFamily>

    <Style x:Key="MdsSidebarTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MdsUiFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Foreground" Value="{ThemeResource MdsTextSecondaryBrush}" />
    </Style>

    <Style x:Key="MdsCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MdsUiFontFamilyText}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource MdsTextSecondaryBrush}" />
    </Style>

    <Style x:Key="MdsBodyStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MdsUiFontFamilyText}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource MdsTextPrimaryBrush}" />
    </Style>

    <Style x:Key="MdsBodyStrongStyle" TargetType="TextBlock" BasedOn="{StaticResource MdsBodyStyle}">
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="MdsTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MdsUiFontFamily}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="36" />
        <Setter Property="Foreground" Value="{ThemeResource MdsTextPrimaryBrush}" />
    </Style>

    <Style x:Key="MdsSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MdsUiFontFamily}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{ThemeResource MdsTextSecondaryBrush}" />
    </Style>

    <!-- Buttons -->
    <Style x:Key="MdsGhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource MdsTextSecondaryBrush}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontFamily" Value="{StaticResource MdsUiFontFamilyText}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="MdsAccentButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource MdsAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontFamily" Value="{StaticResource MdsUiFontFamilyText}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="MdsRailButtonStyle" TargetType="Button" BasedOn="{StaticResource MdsGhostButtonStyle}">
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="MdsRailToggleStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource MdsTextSecondaryBrush}" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- TreeView item -->
    <Style x:Key="MdsTreeViewItemStyle" TargetType="TreeViewItem">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="FontFamily" Value="{StaticResource MdsUiFontFamilyText}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- Theme picker item -->
    <Style x:Key="MdsThemeItemContainerStyle" TargetType="ListViewItem">
        <Setter Property="Padding" Value="4" />
        <Setter Property="MinHeight" Value="56" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <!-- Mode segmented control -->
    <Style x:Key="MdsSegmentButtonStyle" TargetType="ToggleButton">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="MinWidth" Value="72" />
        <Setter Property="Padding" Value="10,2" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource MdsTextSecondaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource MdsUiFontFamilyText}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <!-- Welcome card -->
    <Style x:Key="MdsActionCardStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource MdsSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource MdsBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="20,18" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="MinHeight" Value="104" />
        <Setter Property="Foreground" Value="{ThemeResource MdsTextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource MdsUiFontFamilyText}" />
    </Style>

    <Style x:Key="MdsMruItemStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{ThemeResource MdsTextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource MdsUiFontFamilyText}" />
    </Style>
</ResourceDictionary>
