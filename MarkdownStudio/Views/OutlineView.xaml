<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MarkdownStudio.Views.OutlineView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MarkdownStudio.Models">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="16,14,16,8" Spacing="2">
            <TextBlock Style="{StaticResource MdsSidebarTitleStyle}" Text="Outline" />
            <TextBlock x:Name="SubtitleText" Style="{StaticResource MdsCaptionStyle}" Text="No headings yet" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <TreeView x:Name="Tree" SelectionMode="Single"
                      ItemsSource="{x:Bind Roots, Mode=OneWay}"
                      ItemInvoked="OnItemInvoked"
                      ItemContainerStyle="{StaticResource MdsTreeViewItemStyle}">
                <TreeView.ItemTemplate>
                    <DataTemplate x:DataType="models:OutlineNode">
                        <TreeViewItem ItemsSource="{x:Bind Children}">
                            <TextBlock Text="{x:Bind Title}" Style="{StaticResource MdsBodyStyle}"
                                       TextTrimming="CharacterEllipsis" />
                        </TreeViewItem>
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </ScrollViewer>

        <Grid Grid.Row="1" x:Name="EmptyState" Visibility="Visible" Padding="24">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" MaxWidth="220">
                <FontIcon Glyph="&#xEA37;" FontSize="28" Foreground="{ThemeResource MdsTextSecondaryBrush}" />
                <TextBlock Style="{StaticResource MdsBodyStyle}" TextAlignment="Center"
                           Text="Add headings to your file and they'll appear here." />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
