<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="MarkdownStudio.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:MarkdownStudio.Views"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Title="Settings"
    PrimaryButtonText="Done"
    DefaultButton="Primary"
    MinWidth="720"
    MaxWidth="980">

    <Grid Height="560" MinWidth="680">
        <muxc:TabView x:Name="Tabs"
                      TabWidthMode="SizeToContent"
                      CanReorderTabs="False"
                      CanDragTabs="False"
                      IsAddTabButtonVisible="False">
            <muxc:TabView.TabItems>
                <muxc:TabViewItem Header="General" IsClosable="False">
                    <muxc:TabViewItem.IconSource>
                        <muxc:SymbolIconSource Symbol="Setting" />
                    </muxc:TabViewItem.IconSource>
                    <views:ThemePickerView x:Name="GeneralPane" />
                </muxc:TabViewItem>
                <muxc:TabViewItem Header="Editor" IsClosable="False">
                    <muxc:TabViewItem.IconSource>
                        <muxc:SymbolIconSource Symbol="Edit" />
                    </muxc:TabViewItem.IconSource>
                    <views:SettingsView x:Name="EditorPane" />
                </muxc:TabViewItem>
                <muxc:TabViewItem Header="Preview" IsClosable="False">
                    <muxc:TabViewItem.IconSource>
                        <muxc:SymbolIconSource Symbol="View" />
                    </muxc:TabViewItem.IconSource>
                    <views:PreviewSettingsView x:Name="PreviewPane" />
                </muxc:TabViewItem>
            </muxc:TabView.TabItems>
        </muxc:TabView>
    </Grid>
</ContentDialog>
