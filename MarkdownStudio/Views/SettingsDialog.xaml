<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="MarkdownStudio.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:MarkdownStudio.Views"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    DefaultButton="None">

    <!-- Override the default ContentDialog width caps so this dialog can be
         wide enough for the 2-column tab layout (320px controls + Sample.md
         preview on the right) without crushing the preview side. Also alias
         ContentDialogBackground / BorderBrush to our theme brushes so the
         dialog's own popup chrome adopts the active app theme (otherwise the
         frame around the body stays system-light even in Sepia / Solarized). -->
    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">1200</x:Double>
        <x:Double x:Key="ContentDialogMinWidth">900</x:Double>
        <StaticResource x:Key="ContentDialogBackground"  ResourceKey="MdsWindowBrush" />
        <StaticResource x:Key="ContentDialogBorderBrush" ResourceKey="MdsBorderBrush" />
        <StaticResource x:Key="ContentDialogForeground"  ResourceKey="MdsTextPrimaryBrush" />

        <!-- Tab strip — the selected tab uses its own chrome brushes that
             default to light-grey regardless of our window theme. Alias them
             so the selected tab adopts a subtly lighter card on top of the
             dialog body in every theme. -->
        <StaticResource x:Key="TabViewBackground"
                        ResourceKey="MdsWindowBrush" />
        <StaticResource x:Key="TabViewItemHeaderBackgroundSelected"
                        ResourceKey="MdsSurfaceBrush" />
        <StaticResource x:Key="TabViewItemHeaderBackgroundSelectedPointerOver"
                        ResourceKey="MdsSurfaceBrush" />
        <StaticResource x:Key="TabViewItemHeaderBackgroundSelectedPressed"
                        ResourceKey="MdsSurfaceBrush" />
        <StaticResource x:Key="TabViewItemHeaderForegroundSelected"
                        ResourceKey="MdsTextPrimaryBrush" />
        <StaticResource x:Key="TabViewItemHeaderForegroundSelectedPointerOver"
                        ResourceKey="MdsTextPrimaryBrush" />
        <StaticResource x:Key="TabViewItemHeaderForegroundSelectedPressed"
                        ResourceKey="MdsTextPrimaryBrush" />
    </ContentDialog.Resources>

    <Grid Width="1080" Height="640"
          Background="{ThemeResource MdsWindowBrush}">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscape" />
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom header: title on the left, X close button on the right -->
        <Grid Grid.Row="0" Padding="20,12,12,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Settings"
                       FontFamily="{StaticResource MdsUiFontFamily}"
                       FontSize="18" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource MdsTextPrimaryBrush}" />
            <Button Grid.Column="1" Click="OnCloseClicked"
                    Style="{StaticResource MdsGhostButtonStyle}"
                    Width="36" Height="36"
                    ToolTipService.ToolTip="Close (Esc)">
                <FontIcon Glyph="&#xE8BB;" FontSize="12" />
            </Button>
        </Grid>

        <muxc:TabView Grid.Row="1" x:Name="Tabs"
                      TabWidthMode="SizeToContent"
                      CanReorderTabs="False"
                      CanDragTabs="False"
                      IsAddTabButtonVisible="False">
            <muxc:TabView.TabItems>
                <muxc:TabViewItem Header="General" IsClosable="False">
                    <muxc:TabViewItem.IconSource>
                        <muxc:SymbolIconSource Symbol="Setting" />
                    </muxc:TabViewItem.IconSource>
                    <views:ThemePickerView x:Name="GeneralPane" />
                </muxc:TabViewItem>
                <muxc:TabViewItem Header="Editor" IsClosable="False">
                    <muxc:TabViewItem.IconSource>
                        <muxc:SymbolIconSource Symbol="Edit" />
                    </muxc:TabViewItem.IconSource>
                    <views:SettingsView x:Name="EditorPane" />
                </muxc:TabViewItem>
                <muxc:TabViewItem Header="Preview" IsClosable="False">
                    <muxc:TabViewItem.IconSource>
                        <muxc:SymbolIconSource Symbol="View" />
                    </muxc:TabViewItem.IconSource>
                    <views:PreviewSettingsView x:Name="PreviewPane" />
                </muxc:TabViewItem>
                <muxc:TabViewItem Header="Shortcuts" IsClosable="False">
                    <muxc:TabViewItem.IconSource>
                        <muxc:FontIconSource Glyph="&#xE765;" />
                    </muxc:TabViewItem.IconSource>
                    <views:KeyboardShortcutsView x:Name="ShortcutsPane" />
                </muxc:TabViewItem>
            </muxc:TabView.TabItems>
        </muxc:TabView>
    </Grid>
</ContentDialog>
