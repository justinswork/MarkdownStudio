<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MarkdownStudio.Views.WelcomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MarkdownStudio.Models">

    <UserControl.Resources>
        <DataTemplate x:Key="MruItemTemplate" x:DataType="models:MruEntry">
            <Button Click="OnMruClicked" Tag="{x:Bind}"
                    Style="{StaticResource MdsMruItemStyle}">
                <Button.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="{x:Bind PinMenuText}" Click="OnPinClicked" Tag="{x:Bind}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="{x:Bind PinMenuGlyph}" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Remove from list" Click="OnRemoveClicked" Tag="{x:Bind}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74D;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.ContextFlyout>
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="{x:Bind Glyph}" FontSize="16"
                              Foreground="{ThemeResource MdsTextSecondaryBrush}" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Style="{StaticResource MdsBodyStrongStyle}"
                                   Text="{x:Bind DisplayName}" />
                        <TextBlock Style="{StaticResource MdsCaptionStyle}"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{x:Bind ParentLocation}" />
                    </StackPanel>
                    <FontIcon Grid.Column="2" Glyph="&#xE840;" FontSize="12"
                              Foreground="{ThemeResource MdsAccentBrush}"
                              VerticalAlignment="Center"
                              Margin="0,0,4,0"
                              Visibility="{x:Bind PinIndicatorVisibility}" />
                    <TextBlock Grid.Column="3" Style="{StaticResource MdsCaptionStyle}"
                               VerticalAlignment="Center"
                               Text="{x:Bind RelativeWhen}" />
                </Grid>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{ThemeResource MdsWindowBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
            <Grid Padding="48,64,48,64" HorizontalAlignment="Center" MaxWidth="1180" ColumnSpacing="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="380" />
                </Grid.ColumnDefinitions>

                <!-- LEFT column: hero + primary actions, sharing the same edges -->
                <StackPanel Grid.Column="0" Spacing="44" VerticalAlignment="Top">

                    <!-- Hero -->
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource MdsTitleStyle}" Text="Markdown Studio" />
                        <TextBlock Style="{StaticResource MdsSubtitleStyle}" TextWrapping="Wrap"
                                   Text="A premium markdown editor for Windows. Open a folder to browse your notes, or jump straight into a file." />
                    </StackPanel>

                    <!-- Primary actions -->
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Click="OnOpenFolder" Style="{StaticResource MdsActionCardStyle}">
                            <StackPanel Spacing="10">
                                <FontIcon Glyph="&#xE8B7;" FontSize="22"
                                          Foreground="{ThemeResource MdsAccentBrush}"
                                          HorizontalAlignment="Left" />
                                <TextBlock Style="{StaticResource MdsBodyStrongStyle}" FontSize="14" Text="Open folder" />
                                <TextBlock Style="{StaticResource MdsCaptionStyle}" TextWrapping="Wrap"
                                           Text="Browse markdown files in a workspace." />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1" Click="OnOpenFile" Style="{StaticResource MdsActionCardStyle}">
                            <StackPanel Spacing="10">
                                <FontIcon Glyph="&#xE8E5;" FontSize="22"
                                          Foreground="{ThemeResource MdsAccentBrush}"
                                          HorizontalAlignment="Left" />
                                <TextBlock Style="{StaticResource MdsBodyStrongStyle}" FontSize="14" Text="Open file" />
                                <TextBlock Style="{StaticResource MdsCaptionStyle}" TextWrapping="Wrap"
                                           Text="Pick a single .md to edit." />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2" Click="OnNewFile" Style="{StaticResource MdsActionCardStyle}">
                            <StackPanel Spacing="10">
                                <FontIcon Glyph="&#xE710;" FontSize="22"
                                          Foreground="{ThemeResource MdsAccentBrush}"
                                          HorizontalAlignment="Left" />
                                <TextBlock Style="{StaticResource MdsBodyStrongStyle}" FontSize="14" Text="New file" />
                                <TextBlock Style="{StaticResource MdsCaptionStyle}" TextWrapping="Wrap"
                                           Text="Start from a blank document." />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- RIGHT column: pinned + recent MRU -->
                <StackPanel Grid.Column="1" Spacing="18" VerticalAlignment="Top">

                    <!-- Pinned section -->
                    <StackPanel x:Name="PinnedSection" Spacing="12" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource MdsSidebarTitleStyle}" Text="PINNED" />
                        <ItemsControl x:Name="PinnedList"
                                      ItemsSource="{x:Bind PinnedEntries, Mode=OneWay}"
                                      ItemTemplate="{StaticResource MruItemTemplate}" />
                    </StackPanel>

                    <!-- Recent section -->
                    <StackPanel Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource MdsSidebarTitleStyle}"
                                       Text="RECENT" VerticalAlignment="Center" />
                            <Button Grid.Column="1" x:Name="ClearAllButton" Visibility="Collapsed"
                                    Click="OnClearAll" Style="{StaticResource MdsGhostButtonStyle}"
                                    Content="Clear" />
                        </Grid>

                        <ItemsControl x:Name="RecentList"
                                      ItemsSource="{x:Bind RecentEntries, Mode=OneWay}"
                                      ItemTemplate="{StaticResource MruItemTemplate}" />

                        <TextBlock x:Name="EmptyText" Style="{StaticResource MdsCaptionStyle}"
                                   Text="Nothing yet — open a file or folder to get started."
                                   Visibility="Collapsed" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
