<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MarkdownStudio.Views.WelcomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MarkdownStudio.Models">

    <Grid Background="{ThemeResource MdsWindowBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
            <Grid Padding="48,64,48,64" HorizontalAlignment="Center" MaxWidth="920">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Hero -->
                <StackPanel Grid.Row="0" Spacing="12" Margin="0,0,0,40">
                    <TextBlock Style="{StaticResource MdsTitleStyle}" Text="Markdown Studio" />
                    <TextBlock Style="{StaticResource MdsSubtitleStyle}" MaxWidth="640"
                               TextWrapping="Wrap"
                               Text="A premium markdown editor for Windows. Open a folder to browse your notes, or jump straight into a file." />
                </StackPanel>

                <!-- Primary actions -->
                <Grid Grid.Row="1" ColumnSpacing="14" Margin="0,0,0,48">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Click="OnOpenFolder" Style="{StaticResource MdsActionCardStyle}">
                        <StackPanel Spacing="10">
                            <FontIcon Glyph="&#xE8B7;" FontSize="22"
                                      Foreground="{ThemeResource MdsAccentBrush}"
                                      HorizontalAlignment="Left" />
                            <TextBlock Style="{StaticResource MdsBodyStrongStyle}" FontSize="14" Text="Open folder" />
                            <TextBlock Style="{StaticResource MdsCaptionStyle}" TextWrapping="Wrap"
                                       Text="Browse markdown files in a workspace." />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="1" Click="OnOpenFile" Style="{StaticResource MdsActionCardStyle}">
                        <StackPanel Spacing="10">
                            <FontIcon Glyph="&#xE8E5;" FontSize="22"
                                      Foreground="{ThemeResource MdsAccentBrush}"
                                      HorizontalAlignment="Left" />
                            <TextBlock Style="{StaticResource MdsBodyStrongStyle}" FontSize="14" Text="Open file" />
                            <TextBlock Style="{StaticResource MdsCaptionStyle}" TextWrapping="Wrap"
                                       Text="Pick a single .md to edit." />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Click="OnNewFile" Style="{StaticResource MdsActionCardStyle}">
                        <StackPanel Spacing="10">
                            <FontIcon Glyph="&#xE8E5;" FontSize="22"
                                      Foreground="{ThemeResource MdsAccentBrush}"
                                      HorizontalAlignment="Left" />
                            <TextBlock Style="{StaticResource MdsBodyStrongStyle}" FontSize="14" Text="New file" />
                            <TextBlock Style="{StaticResource MdsCaptionStyle}" TextWrapping="Wrap"
                                       Text="Start from a blank document." />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Recent folders -->
                <StackPanel Grid.Row="2" Margin="0,0,0,36" Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource MdsSidebarTitleStyle}"
                                   Text="RECENT FOLDERS" />
                        <Button Grid.Column="1" x:Name="ClearFoldersButton" Visibility="Collapsed"
                                Click="OnClearFolders" Style="{StaticResource MdsGhostButtonStyle}"
                                Content="Clear" />
                    </Grid>
                    <ItemsControl x:Name="RecentFoldersList" ItemsSource="{x:Bind RecentFolders, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:MruEntry">
                                <Button Click="OnMruClicked" DataContext="{x:Bind}"
                                        Style="{StaticResource MdsMruItemStyle}">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE8B7;" FontSize="16"
                                                  Foreground="{ThemeResource MdsTextSecondaryBrush}" />
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Style="{StaticResource MdsBodyStrongStyle}"
                                                       Text="{x:Bind DisplayName}" />
                                            <TextBlock Style="{StaticResource MdsCaptionStyle}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{x:Bind ParentLocation}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Style="{StaticResource MdsCaptionStyle}"
                                                   VerticalAlignment="Center"
                                                   Text="{x:Bind RelativeWhen}" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="FoldersEmptyText" Style="{StaticResource MdsCaptionStyle}"
                               Text="No folders yet — open one to get started."
                               Visibility="Collapsed" />
                </StackPanel>

                <!-- Recent files -->
                <StackPanel Grid.Row="3" Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource MdsSidebarTitleStyle}"
                                   Text="RECENT FILES" />
                        <Button Grid.Column="1" x:Name="ClearFilesButton" Visibility="Collapsed"
                                Click="OnClearFiles" Style="{StaticResource MdsGhostButtonStyle}"
                                Content="Clear" />
                    </Grid>
                    <ItemsControl x:Name="RecentFilesList" ItemsSource="{x:Bind RecentFiles, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:MruEntry">
                                <Button Click="OnMruClicked" DataContext="{x:Bind}"
                                        Style="{StaticResource MdsMruItemStyle}">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE8A5;" FontSize="16"
                                                  Foreground="{ThemeResource MdsTextSecondaryBrush}" />
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Style="{StaticResource MdsBodyStrongStyle}"
                                                       Text="{x:Bind DisplayName}" />
                                            <TextBlock Style="{StaticResource MdsCaptionStyle}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{x:Bind ParentLocation}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Style="{StaticResource MdsCaptionStyle}"
                                                   VerticalAlignment="Center"
                                                   Text="{x:Bind RelativeWhen}" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="FilesEmptyText" Style="{StaticResource MdsCaptionStyle}"
                               Text="No files yet — open one to get started."
                               Visibility="Collapsed" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
