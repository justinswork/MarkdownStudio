<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MarkdownStudio.Views.FileTreeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MarkdownStudio.Models">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="16,14,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.ColumnSpan="2" x:Name="OpenedPulseBorder"
                    Margin="-16,-14,-12,-8" Opacity="0" IsHitTestVisible="False">
                <Border.Background>
                    <SolidColorBrush x:Name="OpenedPulseBrush" />
                </Border.Background>
            </Border>

            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock x:Name="FolderNameText" Style="{StaticResource MdsSidebarTitleStyle}" Text="No folder" />
                <TextBlock x:Name="FolderPathText" Style="{StaticResource MdsCaptionStyle}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <Button Grid.Column="1" x:Name="OpenFolderButton" Click="OnOpenFolder"
                    Style="{StaticResource MdsGhostButtonStyle}" ToolTipService.ToolTip="Open folder">
                <FontIcon Glyph="&#xED25;" FontSize="14" />
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <TreeView x:Name="Tree" SelectionMode="Single"
                      ItemsSource="{x:Bind Roots, Mode=OneWay}"
                      ItemInvoked="OnItemInvoked"
                      ItemContainerStyle="{StaticResource MdsTreeViewItemStyle}">
                <TreeView.ItemTemplate>
                    <DataTemplate x:DataType="models:FileTreeNode">
                        <TreeViewItem ItemsSource="{x:Bind Children}">
                            <StackPanel Orientation="Horizontal" Spacing="8" Padding="0,2">
                                <FontIcon FontSize="14" Glyph="{x:Bind Glyph}"
                                          Foreground="{ThemeResource MdsTextSecondaryBrush}" />
                                <TextBlock Text="{x:Bind Name}" Style="{StaticResource MdsBodyStyle}" />
                            </StackPanel>
                        </TreeViewItem>
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </ScrollViewer>

        <Grid Grid.Row="1" x:Name="EmptyState" Visibility="Visible" Padding="24">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" MaxWidth="220">
                <FontIcon Glyph="&#xE8B7;" FontSize="28" Foreground="{ThemeResource MdsTextSecondaryBrush}" />
                <TextBlock Style="{StaticResource MdsBodyStyle}" TextAlignment="Center"
                           Text="Open a folder to browse its markdown files." />
                <Button Click="OnOpenFolder" Style="{StaticResource MdsAccentButtonStyle}"
                        HorizontalAlignment="Center" Content="Open folder" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
