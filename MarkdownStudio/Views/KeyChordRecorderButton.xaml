<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MarkdownStudio.Views.KeyChordRecorderButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- A toggle-like button that displays the current chord. When the user
         clicks it, swaps to "Press a key…" and listens for the next chord on
         KeyDown. Esc cancels. Plain modifier presses are ignored. -->
    <Button x:Name="RecordButton" Click="OnRecordClicked"
            Style="{StaticResource MdsGhostButtonStyle}"
            BorderBrush="{ThemeResource MdsBorderBrush}"
            BorderThickness="1"
            MinWidth="160"
            HorizontalContentAlignment="Center"
            CornerRadius="6"
            Padding="10,6"
            ToolTipService.ToolTip="Click to record a new shortcut. Esc to cancel.">
        <TextBlock x:Name="ChordText"
                   Text="Unbound"
                   FontFamily="{StaticResource MdsUiFontFamilyText}"
                   FontSize="13" />
    </Button>
</UserControl>
