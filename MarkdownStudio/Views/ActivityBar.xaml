<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MarkdownStudio.Views.ActivityBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="52">

    <Grid Background="{ThemeResource MdsRailBrush}"
          BorderBrush="{ThemeResource MdsBorderBrush}" BorderThickness="0,0,1,0">
        <StackPanel Orientation="Vertical" VerticalAlignment="Top" Spacing="2" Padding="6,12">

            <Button x:Name="HomeButton" Click="OnHomeClicked"
                    Style="{StaticResource MdsRailButtonStyle}" ToolTipService.ToolTip="Home (Welcome)">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE80F;" FontSize="16" />
            </Button>

            <Border Height="1" Margin="6,6" Background="{ThemeResource MdsBorderBrush}" />

            <ToggleButton x:Name="FilesBtn" Click="OnPaneClicked"
                          Style="{StaticResource MdsRailToggleStyle}" Tag="files"
                          ToolTipService.ToolTip="Files (Ctrl+Shift+E)">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8B7;" FontSize="16" />
            </ToggleButton>

            <ToggleButton x:Name="SearchBtn" Click="OnPaneClicked"
                          Style="{StaticResource MdsRailToggleStyle}" Tag="search"
                          ToolTipService.ToolTip="Search (Ctrl+Shift+F)">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE721;" FontSize="16" />
            </ToggleButton>

            <ToggleButton x:Name="OutlineBtn" Click="OnPaneClicked"
                          Style="{StaticResource MdsRailToggleStyle}" Tag="outline"
                          ToolTipService.ToolTip="Outline (Ctrl+Shift+O)">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEA37;" FontSize="16" />
            </ToggleButton>

            <Button x:Name="SettingsBtn" Click="OnSettingsClicked"
                    Style="{StaticResource MdsRailButtonStyle}"
                    ToolTipService.ToolTip="Settings">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE713;" FontSize="16" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
