<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MarkdownStudio.Views.ThemePickerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MarkdownStudio.Models">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="16,14,16,8" Spacing="2">
            <TextBlock Style="{StaticResource MdsSidebarTitleStyle}" Text="Themes" />
            <TextBlock Style="{StaticResource MdsCaptionStyle}" Text="Pick a look. Saved across sessions." />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,4,12,12">
            <ListView x:Name="ThemeList"
                      ItemsSource="{x:Bind Items}"
                      SelectionChanged="OnSelectionChanged"
                      SelectionMode="Single"
                      ItemContainerStyle="{StaticResource MdsThemeItemContainerStyle}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:AppTheme">
                        <Grid Padding="8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Width="56" Height="40" CornerRadius="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{x:Bind RailFill}" />
                                    </Border.Background>
                                </Border>
                                <Border Grid.Column="1">
                                    <Border.Background>
                                        <SolidColorBrush Color="{x:Bind SidebarFill}" />
                                    </Border.Background>
                                    <Grid Padding="6">
                                        <Border CornerRadius="2" Height="3" VerticalAlignment="Top" HorizontalAlignment="Left" Width="22">
                                            <Border.Background>
                                                <SolidColorBrush Color="{x:Bind AccentColor}" />
                                            </Border.Background>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                <TextBlock Text="{x:Bind DisplayName}" Style="{StaticResource MdsBodyStrongStyle}" />
                                <TextBlock Text="{x:Bind Id}" Style="{StaticResource MdsCaptionStyle}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</UserControl>
