<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MarkdownStudio.Views.ThemePickerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MarkdownStudio.Models">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="16,14,16,8" Spacing="2">
            <TextBlock Style="{StaticResource MdsSidebarTitleStyle}" Text="Themes" />
            <TextBlock Style="{StaticResource MdsCaptionStyle}" Text="Pick a look. Saved across sessions." />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,4,12,12">
            <ListView x:Name="ThemeList"
                      ItemsSource="{x:Bind Items}"
                      SelectionChanged="OnSelectionChanged"
                      SelectionMode="Single"
                      ItemContainerStyle="{StaticResource MdsThemeItemContainerStyle}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:AppTheme">
                        <Grid Padding="8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Width="56" Height="40" CornerRadius="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{x:Bind RailFill}" />
                                    </Border.Background>
                                </Border>
                                <Border Grid.Column="1">
                                    <Border.Background>
                                        <SolidColorBrush Color="{x:Bind SidebarFill}" />
                                    </Border.Background>
                                    <Grid Padding="6">
                                        <Border CornerRadius="2" Height="3" VerticalAlignment="Top" HorizontalAlignment="Left" Width="22">
                                            <Border.Background>
                                                <SolidColorBrush Color="{x:Bind AccentColor}" />
                                            </Border.Background>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                <TextBlock Text="{x:Bind DisplayName}" Style="{StaticResource MdsBodyStrongStyle}" />
                                <TextBlock Text="{x:Bind Id}" Style="{StaticResource MdsCaptionStyle}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>

        <!-- File associations: opens Windows' Default Apps page so the user
             can opt in to Markdown Studio handling .md / .markdown / etc.
             We can't actually flip the registration ourselves from a sandboxed
             MSIX app — Windows owns that choice — so this is just a shortcut. -->
        <Border Grid.Row="2" Margin="16,4,16,16" Padding="14,12"
                CornerRadius="8"
                Background="{ThemeResource MdsSurfaceBrush}"
                BorderBrush="{ThemeResource MdsBorderBrush}"
                BorderThickness="1">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource MdsBodyStrongStyle}"
                               Text="File associations" />
                    <TextBlock Style="{StaticResource MdsCaptionStyle}"
                               TextWrapping="Wrap"
                               Text="Make Markdown Studio the default app for .md and other Markdown files. Opens Windows Settings → Default apps." />
                </StackPanel>
                <Button Grid.Column="1" Click="OnOpenDefaultApps"
                        Style="{StaticResource MdsAccentButtonStyle}"
                        VerticalAlignment="Center"
                        Content="Set as default…" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
