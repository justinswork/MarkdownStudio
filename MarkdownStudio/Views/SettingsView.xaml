<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MarkdownStudio.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MarkdownStudio.Models"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <Grid ColumnSpacing="24" Padding="20,16,20,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: controls -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="22">
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource MdsBodyStrongStyle}" Text="Editor font" />
                    <ComboBox x:Name="FontCombo" HorizontalAlignment="Stretch"
                              ItemsSource="{x:Bind FontPresetsList}"
                              SelectionChanged="OnFontChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:FontPreset">
                                <TextBlock Text="{x:Bind DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource MdsBodyStrongStyle}" Text="Font size" />
                        <TextBlock Grid.Column="1" x:Name="FontSizeText"
                                   Style="{StaticResource MdsCaptionStyle}" VerticalAlignment="Center"
                                   Text="14 pt" />
                    </Grid>
                    <Slider x:Name="FontSizeSlider" Minimum="10" Maximum="24" StepFrequency="1"
                            TickFrequency="2" TickPlacement="Outside"
                            ValueChanged="OnFontSizeChanged" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource MdsBodyStrongStyle}" Text="Tab size" />
                        <TextBlock Grid.Column="1" x:Name="TabSizeText"
                                   Style="{StaticResource MdsCaptionStyle}" VerticalAlignment="Center"
                                   Text="2 spaces" />
                    </Grid>
                    <Slider x:Name="TabSizeSlider" Minimum="1" Maximum="8" StepFrequency="1"
                            TickFrequency="1" TickPlacement="Outside"
                            ValueChanged="OnTabSizeChanged" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource MdsBodyStrongStyle}" Text="Show whitespace" />
                    <TextBlock Style="{StaticResource MdsCaptionStyle}" TextWrapping="Wrap"
                               Text="Render spaces and tabs as visible characters in the editor." />
                    <ToggleSwitch x:Name="WhitespaceToggle" Toggled="OnWhitespaceToggled"
                                  OffContent="Off" OnContent="On" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Right: real Monaco rendering Sample.md in read-only mode -->
        <Grid Grid.Column="1" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Style="{StaticResource MdsCaptionStyle}"
                       Text="Preview · Sample.md in a read-only editor" />
            <Border Grid.Row="1"
                    Background="{ThemeResource MdsSurfaceBrush}"
                    BorderBrush="{ThemeResource MdsBorderBrush}" BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <controls:WebView2 x:Name="EditorWebView" />
                    <ProgressRing x:Name="LoadingRing" IsActive="True"
                                  Width="32" Height="32"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
