<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MarkdownStudio.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MarkdownStudio.Models">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="16,14,16,8" Spacing="2">
            <TextBlock Style="{StaticResource MdsSidebarTitleStyle}" Text="SETTINGS" />
            <TextBlock Style="{StaticResource MdsCaptionStyle}" Text="Saved across sessions." />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,8,16,16">
            <StackPanel Spacing="22">

                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource MdsBodyStrongStyle}" Text="Editor font" />
                    <ComboBox x:Name="FontCombo" HorizontalAlignment="Stretch"
                              ItemsSource="{x:Bind FontPresetsList}"
                              SelectionChanged="OnFontChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:FontPreset">
                                <TextBlock Text="{x:Bind DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource MdsBodyStrongStyle}" Text="Font size" />
                        <TextBlock Grid.Column="1" x:Name="FontSizeText"
                                   Style="{StaticResource MdsCaptionStyle}" VerticalAlignment="Center"
                                   Text="14 pt" />
                    </Grid>
                    <Slider x:Name="FontSizeSlider" Minimum="10" Maximum="24" StepFrequency="1"
                            TickFrequency="2" TickPlacement="Outside"
                            ValueChanged="OnFontSizeChanged" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource MdsBodyStrongStyle}" Text="Tab size" />
                        <TextBlock Grid.Column="1" x:Name="TabSizeText"
                                   Style="{StaticResource MdsCaptionStyle}" VerticalAlignment="Center"
                                   Text="2 spaces" />
                    </Grid>
                    <Slider x:Name="TabSizeSlider" Minimum="1" Maximum="8" StepFrequency="1"
                            TickFrequency="1" TickPlacement="Outside"
                            ValueChanged="OnTabSizeChanged" />
                </StackPanel>

                <Border BorderBrush="{ThemeResource MdsBorderBrush}" BorderThickness="0,1,0,0" Margin="0,8,0,0" />

                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource MdsCaptionStyle}" Text="Preview" />
                    <Border Background="{ThemeResource MdsSurfaceBrush}"
                            BorderBrush="{ThemeResource MdsBorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="14,10">
                        <TextBlock x:Name="PreviewText"
                                   Text="The quick brown fox jumps over the lazy dog 0123456789"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
