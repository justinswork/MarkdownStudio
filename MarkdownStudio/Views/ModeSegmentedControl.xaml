<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MarkdownStudio.Views.ModeSegmentedControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border CornerRadius="6" BorderThickness="1"
            BorderBrush="{ThemeResource MdsBorderBrush}"
            Background="{ThemeResource MdsSidebarBrush}"
            Padding="2">
        <StackPanel Orientation="Horizontal" Spacing="2">
            <ToggleButton x:Name="EditorBtn" Tag="editor" Click="OnClicked"
                          Style="{StaticResource MdsSegmentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="12" Glyph="&#xE70F;" />
                    <TextBlock Text="Editor" />
                </StackPanel>
            </ToggleButton>
            <ToggleButton x:Name="SplitBtn" Tag="split" Click="OnClicked"
                          Style="{StaticResource MdsSegmentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="12" Glyph="&#xE78B;" />
                    <TextBlock Text="Split" />
                </StackPanel>
            </ToggleButton>
            <ToggleButton x:Name="PreviewBtn" Tag="preview" Click="OnClicked"
                          Style="{StaticResource MdsSegmentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="12" Glyph="&#xE890;" />
                    <TextBlock Text="Preview" />
                </StackPanel>
            </ToggleButton>
        </StackPanel>
    </Border>
</UserControl>
