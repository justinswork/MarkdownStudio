<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MarkdownStudio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MarkdownStudio"
    xmlns:views="using:MarkdownStudio.Views"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Title="Markdown Studio">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="F11" Invoked="OnToggleFocus" />
            <KeyboardAccelerator Modifiers="Control" Key="N" Invoked="OnNewAccel" />
            <KeyboardAccelerator Modifiers="Control" Key="O" Invoked="OnOpenAccel" />
            <KeyboardAccelerator Modifiers="Control,Shift" Key="O" Invoked="OnOpenFolderAccel" />
            <KeyboardAccelerator Modifiers="Control" Key="S" Invoked="OnSaveAccel" />
            <KeyboardAccelerator Modifiers="Control,Shift" Key="S" Invoked="OnSaveAsAccel" />
            <KeyboardAccelerator Modifiers="Control" Key="W" Invoked="OnCloseTabAccel" />
        </Grid.KeyboardAccelerators>

        <!-- Title bar with menu inline -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="40" Padding="0,0,140,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="16,0,16,0" Spacing="10">
                <FontIcon Glyph="&#xE7C3;" FontSize="16"
                          Foreground="{ThemeResource MdsAccentBrush}" />
                <TextBlock Text="Markdown Studio" VerticalAlignment="Center"
                           FontFamily="{StaticResource MdsUiFontFamily}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{ThemeResource MdsTextPrimaryBrush}" />
            </StackPanel>

            <MenuBar x:Name="AppMenuBar" Grid.Column="1" VerticalAlignment="Center" Background="Transparent">
                <MenuBarItem Title="File">
                    <MenuFlyoutItem Text="New" Click="OnNew">
                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8E5;" /></MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Open file..." Click="OnOpenFile">
                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8E5;" /></MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Open folder..." Click="OnOpenFolder">
                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8B7;" /></MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Save" Click="OnSave" />
                    <MenuFlyoutItem Text="Save as..." Click="OnSaveAs" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Show Welcome" Click="OnShowWelcome" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Close tab" Click="OnCloseTab" />
                    <MenuFlyoutItem Text="Exit" Click="OnExit" />
                </MenuBarItem>
                <MenuBarItem Title="View">
                    <MenuFlyoutItem Text="Editor + Preview" Click="OnSplitMode" />
                    <MenuFlyoutItem Text="Editor only" Click="OnEditorMode" />
                    <MenuFlyoutItem Text="Preview only" Click="OnPreviewMode" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Toggle word wrap" Click="OnToggleWordWrap" />
                    <MenuFlyoutItem Text="Toggle distraction-free mode" Click="OnToggleFocusMenu">
                        <MenuFlyoutItem.KeyboardAcceleratorTextOverride>F11</MenuFlyoutItem.KeyboardAcceleratorTextOverride>
                    </MenuFlyoutItem>
                </MenuBarItem>
                <MenuBarItem Title="Help">
                    <MenuFlyoutItem Text="About Markdown Studio" Click="OnAbout" />
                </MenuBarItem>
            </MenuBar>
        </Grid>

        <!-- Body: rail + sidebar + main column -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" x:Name="RailColumn" />
                <ColumnDefinition Width="Auto" x:Name="SidebarColumn" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <views:ActivityBar x:Name="ActivityRail" Grid.Column="0" />

            <Grid x:Name="SidebarHost" Grid.Column="1" Width="280"
                  Background="{ThemeResource MdsSidebarBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border BorderBrush="{ThemeResource MdsBorderBrush}" BorderThickness="0,0,1,0">
                    <ContentPresenter x:Name="SidebarPresenter"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalContentAlignment="Stretch" />
                </Border>
            </Grid>

            <Grid Grid.Column="2" Background="{ThemeResource MdsWindowBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Padding="12,8" x:Name="TopToolbar">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <views:ModeSegmentedControl x:Name="ModeControl" />
                        <Button x:Name="FocusButton" Click="OnToggleFocus"
                                Style="{StaticResource MdsGhostButtonStyle}"
                                ToolTipService.ToolTip="Distraction-free mode (F11)">
                            <FontIcon Glyph="&#xE740;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </Grid>

                <muxc:TabView x:Name="Tabs" Grid.Row="1"
                              TabWidthMode="SizeToContent"
                              CanReorderTabs="True"
                              CanDragTabs="True"
                              IsAddTabButtonVisible="True"
                              TabCloseRequested="Tabs_TabCloseRequested"
                              AddTabButtonClick="Tabs_AddTabButtonClick"
                              SelectionChanged="Tabs_SelectionChanged" />

                <ContentPresenter x:Name="ActiveContent" Grid.Row="2"
                                  HorizontalContentAlignment="Stretch"
                                  VerticalContentAlignment="Stretch" />
            </Grid>
        </Grid>

        <Grid Grid.Row="2" x:Name="StatusBar" Height="26"
              Background="{ThemeResource MdsRailBrush}"
              BorderBrush="{ThemeResource MdsBorderBrush}" BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" Margin="14,0" VerticalAlignment="Center">
                <TextBlock x:Name="StatusText" Style="{StaticResource MdsCaptionStyle}" Text="Ready" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14" Margin="0,0,14,0" VerticalAlignment="Center">
                <TextBlock x:Name="ThemeStatusText" Style="{StaticResource MdsCaptionStyle}" Text="Daylight" />
                <TextBlock Style="{StaticResource MdsCaptionStyle}" Text="·" />
                <TextBlock x:Name="DocInfoText" Style="{StaticResource MdsCaptionStyle}" Text="Markdown · UTF-8" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
